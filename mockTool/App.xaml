<Application x:Class="MockDiagTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- HandyControl global style resources -->
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml" />
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml" />
                <!-- Default language resources (can be replaced at runtime) -->
                <ResourceDictionary Source="Resources/Strings.zh-CN.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Fixed palette (no runtime theme switching) -->
            <Color x:Key="ThemeBg">#F7F8FA</Color>
            <Color x:Key="ThemeCardBg">#FFFFFF</Color>
            <Color x:Key="ThemeCardBorder">#E3E6EA</Color>
            <Color x:Key="ThemeHeaderBg">#F2F4F7</Color>
            <Color x:Key="ThemeTextPrimary">#1F2937</Color>
            <Color x:Key="ThemeTextSecondary">#667085</Color>
            <Color x:Key="ThemeAccentGreen">#2E9E58</Color>
            <Color x:Key="ThemeAccentOrange">#DD7A1F</Color>
            <Color x:Key="ThemeAccentRed">#D64545</Color>
            <Color x:Key="ThemeRingBg">#E8ECF2</Color>
            <Color x:Key="ThemeRowBorder">#E9EDF2</Color>
            <Color x:Key="ThemePassCardBg">#E9F9EF</Color>
            <Color x:Key="ThemeWarnCardBg">#FFF6DB</Color>
            <Color x:Key="ThemeFailCardBg">#FFEDEE</Color>
            <Color x:Key="ThemePassCardText">#1F7A3A</Color>
            <Color x:Key="ThemeWarnCardText">#9C6E00</Color>
            <Color x:Key="ThemeFailCardText">#B83333</Color>

            <SolidColorBrush x:Key="ThemeBgBrush" Color="{StaticResource ThemeBg}" />
            <SolidColorBrush x:Key="ThemeCardBgBrush" Color="{StaticResource ThemeCardBg}" />
            <SolidColorBrush x:Key="ThemeCardBorderBrush" Color="{StaticResource ThemeCardBorder}" />
            <SolidColorBrush x:Key="ThemeHeaderBgBrush" Color="{StaticResource ThemeHeaderBg}" />
            <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="{StaticResource ThemeTextPrimary}" />
            <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="{StaticResource ThemeTextSecondary}" />
            <SolidColorBrush x:Key="ThemeAccentGreenBrush" Color="{StaticResource ThemeAccentGreen}" />
            <SolidColorBrush x:Key="ThemeAccentOrangeBrush" Color="{StaticResource ThemeAccentOrange}" />
            <SolidColorBrush x:Key="ThemeAccentRedBrush" Color="{StaticResource ThemeAccentRed}" />
            <SolidColorBrush x:Key="ThemeRingBgBrush" Color="{StaticResource ThemeRingBg}" />
            <SolidColorBrush x:Key="ThemeRowBorderBrush" Color="{StaticResource ThemeRowBorder}" />
            <SolidColorBrush x:Key="ThemePassCardBgBrush" Color="{StaticResource ThemePassCardBg}" />
            <SolidColorBrush x:Key="ThemeWarnCardBgBrush" Color="{StaticResource ThemeWarnCardBg}" />
            <SolidColorBrush x:Key="ThemeFailCardBgBrush" Color="{StaticResource ThemeFailCardBg}" />
            <SolidColorBrush x:Key="ThemePassCardTextBrush" Color="{StaticResource ThemePassCardText}" />
            <SolidColorBrush x:Key="ThemeWarnCardTextBrush" Color="{StaticResource ThemeWarnCardText}" />
            <SolidColorBrush x:Key="ThemeFailCardTextBrush" Color="{StaticResource ThemeFailCardText}" />
            <SolidColorBrush x:Key="ThemeSecondaryButtonBg" Color="#E8EDF3" />

            <!-- Shared global tuning -->
            <Style TargetType="Window">
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="Background" Value="{DynamicResource ThemeCardBgBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="Background" Value="{DynamicResource ThemeCardBgBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="FontSize" Value="12.5" />
                <Setter Property="GridLinesVisibility" Value="Horizontal" />
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ThemeRowBorderBrush}" />
                <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource ThemeRowBorderBrush}" />
                <Setter Property="RowBackground" Value="{DynamicResource ThemeCardBgBrush}" />
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource ThemeHeaderBgBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}" />
                <Setter Property="Background" Value="{DynamicResource ThemeCardBgBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}" />
            </Style>

            <Style x:Key="SurfaceCardBorder" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ThemeCardBgBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style x:Key="SoftPanelBorder" TargetType="Border" BasedOn="{StaticResource SurfaceCardBorder}">
                <Setter Property="Background" Value="{DynamicResource ThemeHeaderBgBrush}" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="12" />
            </Style>

            <!-- ── Action Button Styles (theme-aware) ── -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ThemeAccentGreenBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="MinHeight" Value="36" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.88" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.4" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="Background" Value="{DynamicResource ThemeSecondaryButtonBg}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="14,8" />
            </Style>

            <Style x:Key="FixButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="Background" Value="{DynamicResource ThemeAccentOrangeBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Padding" Value="12,6" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
