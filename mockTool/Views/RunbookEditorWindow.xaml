<Window x:Class="MockDiagTool.Views.RunbookEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="{DynamicResource Loc.Editor.Title}"
        Height="760"
        Width="1180"
        MinHeight="680"
        MinWidth="1080"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource ThemeBgBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="{DynamicResource ThemeTextPrimaryBrush}" />
        </Style>
        <Style x:Key="EditorPanelBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource SurfaceCardBorder}">
            <Setter Property="CornerRadius"
                    Value="10" />
            <Setter Property="Padding"
                    Value="10,10,10,8" />
            <Setter Property="Background"
                    Value="{DynamicResource ThemeCardBgBrush}" />
            <Setter Property="BorderBrush"
                    Value="{DynamicResource ThemeCardBorderBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin"
                    Value="0,2,0,8" />
            <Setter Property="Height"
                    Value="32" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin"
                    Value="0,2,0,8" />
            <Setter Property="Height"
                    Value="32" />
        </Style>
        <Style x:Key="ParamsJsonTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="Margin"
                    Value="0,2,0,10" />
            <Setter Property="AcceptsReturn"
                    Value="True" />
            <Setter Property="Height"
                    Value="170" />
            <Setter Property="VerticalScrollBarVisibility"
                    Value="Auto" />
            <Setter Property="TextWrapping"
                    Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedStep.IsParamsJsonValid}"
                             Value="False">
                    <Setter Property="BorderBrush"
                            Value="#E53E3E" />
                    <Setter Property="BorderThickness"
                            Value="2" />
                    <Setter Property="Background"
                            Value="#2B0000" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ParamsErrorTextStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground"
                    Value="#E53E3E" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="Margin"
                    Value="0,0,0,8" />
            <Setter Property="Visibility"
                    Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedStep.IsParamsJsonValid}"
                             Value="False">
                    <Setter Property="Visibility"
                            Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Margin="0,0,0,10"
                Style="{StaticResource EditorPanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{DynamicResource Loc.Editor.Title}"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{DynamicResource Loc.Editor.Subtitle}"
                               Margin="0,4,0,0"
                               FontSize="12.5"
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="{DynamicResource Loc.Editor.ReloadDefault}"
                            Command="{Binding LoadDefaultCommand}"
                            Margin="0,0,6,0" />
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="{DynamicResource Loc.Editor.AutoRelink}"
                            Command="{Binding AutoRelinkCommand}"
                            Margin="0,0,6,0" />
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="{DynamicResource Loc.Editor.AddStep}"
                            Command="{Binding AddStepCommand}"
                            Margin="0,0,6,0" />
                    <Button Style="{StaticResource FixButton}"
                            Content="{DynamicResource Loc.Editor.RemoveCurrent}"
                            Command="{Binding RemoveStepCommand}"
                            CommandParameter="{Binding SelectedStep}" />
                </StackPanel>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Style="{StaticResource EditorPanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{DynamicResource Loc.Editor.StepList}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Steps}"
                              SelectedItem="{Binding SelectedStep, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="False"
                              Style="{StaticResource DataGrid.Small}"
                              BorderBrush="{DynamicResource ThemeCardBorderBrush}"
                              Background="{DynamicResource ThemeCardBgBrush}">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding Enabled, Mode=TwoWay}"
                                                    Header="{DynamicResource Loc.Editor.Col.Enabled}"
                                                    Width="56" />
                            <DataGridTextColumn Binding="{Binding StepId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Header="StepId"
                                                Width="100" />
                            <DataGridTextColumn Binding="{Binding CheckId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Header="CheckId"
                                                Width="110" />
                            <DataGridTextColumn Binding="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Header="{DynamicResource Loc.Editor.Col.DisplayName}"
                                                Width="190" />
                            <DataGridTextColumn Binding="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Header="{DynamicResource Loc.Editor.Col.Category}"
                                                Width="120" />
                            <DataGridTextColumn Binding="{Binding TimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Header="{DynamicResource Loc.Editor.Col.Timeout}"
                                                Width="86" />
                            <DataGridTextColumn Binding="{Binding NextOnSuccess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Header="{DynamicResource Loc.Editor.Col.NextSuccess}"
                                                Width="120" />
                            <DataGridTextColumn Binding="{Binding NextOnFailure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Header="{DynamicResource Loc.Editor.Col.NextFailure}"
                                                Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Width="10" />
            <Border Grid.Column="2"
                    Style="{StaticResource EditorPanelBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Loc.Editor.StepDetail}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,0,10" />
                        <TextBlock Text="StepId" />
                        <TextBox Text="{Binding SelectedStep.StepId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="CheckId" />
                        <ComboBox ItemsSource="{Binding CheckIdOptions}"
                                  IsEditable="True"
                                  Text="{Binding SelectedStep.CheckId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{DynamicResource Loc.Editor.DisplayName}" />
                        <TextBox Text="{Binding SelectedStep.DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Category" />
                        <ComboBox ItemsSource="{Binding CategoryOptions}"
                                  SelectedItem="{Binding SelectedStep.Category, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{DynamicResource Loc.Editor.TimeoutMs}" />
                        <TextBox Text="{Binding SelectedStep.TimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Content="{DynamicResource Loc.Editor.Enabled}"
                                  IsChecked="{Binding SelectedStep.Enabled, Mode=TwoWay}"
                                  Margin="0,4,0,8" />
                        <TextBlock Text="NextOnSuccess" />
                        <TextBox Text="{Binding SelectedStep.NextOnSuccess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="NextOnFailure" />
                        <TextBox Text="{Binding SelectedStep.NextOnFailure, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="{DynamicResource Loc.Editor.ParamsJson}" />
                        <TextBox Style="{StaticResource ParamsJsonTextBoxStyle}"
                                 Text="{Binding SelectedStep.ParamsJson, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Style="{StaticResource ParamsErrorTextStyle}"
                                   Text="{Binding SelectedStep.ParamsJsonError}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource SecondaryButton}"
                                    Content="{DynamicResource Loc.Editor.MoveUp}"
                                    Command="{Binding MoveUpCommand}"
                                    CommandParameter="{Binding SelectedStep}"
                                    Margin="0,0,6,0" />
                            <Button Style="{StaticResource SecondaryButton}"
                                    Content="{DynamicResource Loc.Editor.MoveDown}"
                                    Command="{Binding MoveDownCommand}"
                                    CommandParameter="{Binding SelectedStep}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
        <Border Grid.Row="2"
                Margin="0,10,0,0"
                Style="{StaticResource EditorPanelBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="RunBook Id"
                                   VerticalAlignment="Center"
                                   Width="90" />
                        <TextBox Text="{Binding RunbookId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="160"
                                 Margin="0,0,14,0"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="Title"
                                   VerticalAlignment="Center"
                                   Width="50" />
                        <TextBox Text="{Binding RunbookTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="300"
                                 Margin="0,0,14,0"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="Version"
                                   VerticalAlignment="Center"
                                   Width="60" />
                        <TextBox Text="{Binding RunbookVersion, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="80"
                                 Margin="0,0,14,0"
                                 VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,8,0,0">
                        <TextBlock Text="{DynamicResource Loc.Editor.SaveAsId}"
                                   VerticalAlignment="Center"
                                   Width="90" />
                        <TextBox Text="{Binding SaveAsRunbookId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="220"
                                 Margin="0,0,12,0" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            >
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="{DynamicResource Loc.Editor.SaveDefault}"
                            Command="{Binding SaveDefaultCommand}"
                            Margin="0,0,8,0" />
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="{DynamicResource Loc.Editor.SaveAs}"
                            Command="{Binding SaveAsCommand}"
                            Margin="0,0,8,0" />
                    <Button Style="{StaticResource SecondaryButton}"
                            Content="{DynamicResource Loc.Editor.Close}"
                            Click="OnCloseClick" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>