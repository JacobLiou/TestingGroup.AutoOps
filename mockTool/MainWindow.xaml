<Window x:Class="MockDiagTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:MockDiagTool.Converters"
        xmlns:model="clr-namespace:MockDiagTool.Models"
        xmlns:vm="clr-namespace:MockDiagTool.ViewModels"
        Title="{DynamicResource Loc.App.Title}"
        Height="800"
        Width="1100"
        MinHeight="700"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemeBgBrush}"
        WindowState="Maximized">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <Window.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor" />
        <conv:StatusToBgConverter x:Key="StatusToBg" />
        <conv:ScoreToColorConverter x:Key="ScoreToColor" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <Style x:Key="SummaryCardBorderStyle"
               TargetType="Border">
            <Setter Property="CornerRadius"
                    Value="12" />
            <Setter Property="Padding"
                    Value="16,12" />
            <Setter Property="Margin"
                    Value="0,4" />
            <Setter Property="BorderBrush"
                    Value="{DynamicResource ThemeCardBorderBrush}" />
            <Setter Property="BorderThickness"
                    Value="1" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!-- ═══════════ HEADER ═══════════ -->
        <Border Grid.Row="0"
                Margin="6,18,6,10"
                Style="{StaticResource SurfaceCardBorder}"
                Padding="24,16"
                Background="{DynamicResource ThemeHeaderBgBrush}">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="🛡"
                               FontSize="28"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{DynamicResource Loc.Main.BrandTitle}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{DynamicResource Loc.Main.RunbookDriven}"
                               FontSize="13"
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,4,0,0" />
                    <TextBlock Text="{Binding CurrentRunbookName, StringFormat=  · RunBook: {0}}"
                               FontSize="13"
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="8,4,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="13"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ExternalConfigStatus}"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding LastReportStatus}"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{DynamicResource Loc.Main.LanguageLabel}"
                               FontSize="12"
                               Margin="22 0 10 0"
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <ComboBox Width="128"
                              Height="28"
                              Margin="0,0,10,0"
                              SelectedValuePath="Tag"
                              SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay}">
                        <ComboBoxItem Content="{DynamicResource Loc.Main.LanguageZhOption}"
                                      Tag="zh-CN" />
                        <ComboBoxItem Content="{DynamicResource Loc.Main.LanguageEnOption}"
                                      Tag="en-US" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>
        <!-- ═══════════ SCORE RING + SCAN AREA ═══════════ -->
        <Border Grid.Row="1"
                Margin="6,0,6,10"
                Style="{StaticResource SurfaceCardBorder}"
                Padding="0,6,0,6">
            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <!-- Score Circle -->
                <Grid Grid.Column="0"
                      Width="180"
                      Height="180">
                    <!-- Background ring -->
                    <Ellipse Stroke="{DynamicResource ThemeRingBgBrush}"
                             StrokeThickness="10" />
                    <!-- Animated ring -->
                    <Ellipse x:Name="ScoreRing"
                             Stroke="{Binding DisplayScore, Converter={StaticResource ScoreToColor}}"
                             StrokeThickness="10"
                             StrokeDashArray="4 1"
                             Opacity="0.85" />
                    <!-- Score text -->
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Width="200">
                        <TextBlock x:Name="ScoreValueText"
                                   Text="{Binding DisplayScore}"
                                   FontSize="56"
                                   FontWeight="Bold"
                                   Foreground="{Binding DisplayScore, Converter={StaticResource ScoreToColor}}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Width="120" />
                        <TextBlock Text="{DynamicResource Loc.Main.HealthScore}"
                                   FontSize="14"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
                <!-- Center: current scanning item + action buttons -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="30,0">
                    <TextBlock x:Name="CurrentScanText"
                               Text="{Binding CurrentScanItem}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                               TextWrapping="Wrap"
                               Width="500"
                               Opacity="1">
                        <TextBlock.RenderTransform>
                            <TranslateTransform Y="0" />
                        </TextBlock.RenderTransform></TextBlock>
                    <TextBlock Margin="0,8,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}">
                        <TextBlock.Text>
                            <Binding Path="ScannedProgressText" />
                        </TextBlock.Text></TextBlock>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,20,0,0">
                        <!-- Start Scan button -->
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="{DynamicResource Loc.Main.StartScan}"
                                Command="{Binding StartScanCommand}"
                                Visibility="{Binding IsScanning, Converter={StaticResource InvBoolToVis}}" />
                        <!-- Stop button -->
                        <Button Style="{StaticResource ButtonDefault}"
                                Content="{DynamicResource Loc.Main.StopScan}"
                                Command="{Binding StopScanCommand}"
                                Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}"
                                Margin="8,0,0,0" />
                        <!-- Fix All button -->
                        <Button Style="{StaticResource FixButton}"
                                Content="{DynamicResource Loc.Main.FixAll}"
                                Command="{Binding FixAllCommand}"
                                Visibility="{Binding ScanComplete, Converter={StaticResource BoolToVis}}"
                                Margin="8,0,0,0" />
                        <Button Style="{StaticResource ButtonDefault}"
                                Content="{DynamicResource Loc.Main.ReportMims}"
                                Command="{Binding SendToMimsCommand}"
                                Margin="8,0,0,0" />
                        <Button Style="{StaticResource ButtonDefault}"
                                Content="{DynamicResource Loc.Main.ExportOnePageReport}"
                                Command="{Binding ExportOnePageReportCommand}"
                                Margin="8,0,0,0" />
                        <Button Style="{StaticResource ButtonDefault}"
                                Content="{DynamicResource Loc.Main.RunbookEditor}"
                                Command="{Binding OpenRunbookEditorCommand}"
                                Visibility="{Binding IsScanning, Converter={StaticResource InvBoolToVis}}"
                                Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
                <!-- Right: summary cards -->
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            Margin="30,0,40,0">
                    <Border Style="{StaticResource SummaryCardBorderStyle}"
                            Background="{DynamicResource ThemePassCardBgBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✅"
                                       FontSize="18"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{DynamicResource Loc.Main.Pass}"
                                       FontSize="14"
                                       Foreground="{DynamicResource ThemePassCardTextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding PassCount}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ThemeAccentGreenBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCardBorderStyle}"
                            Background="{DynamicResource ThemeWarnCardBgBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠️"
                                       FontSize="18"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{DynamicResource Loc.Main.Warning}"
                                       FontSize="14"
                                       Foreground="{DynamicResource ThemeWarnCardTextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding WarningCount}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ThemeAccentOrangeBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCardBorderStyle}"
                            Background="{DynamicResource ThemeFailCardBgBrush}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="❌"
                                       FontSize="18"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{DynamicResource Loc.Main.Fail}"
                                       FontSize="14"
                                       Foreground="{DynamicResource ThemeFailCardTextBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding FailCount}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ThemeAccentRedBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        <!-- ═══════════ RESULT LIST ═══════════ -->
        <Border Grid.Row="2"
                Margin="6,0,6,10"
                Style="{StaticResource SurfaceCardBorder}"
                CornerRadius="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <!-- List header -->
                <Border Grid.Row="0"
                        Padding="20,14"
                        Background="{DynamicResource ThemeHeaderBgBrush}"
                        CornerRadius="14,14,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{DynamicResource Loc.Main.Header.Category}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                        <TextBlock Grid.Column="1"
                                   Text="{DynamicResource Loc.Main.Header.CheckItem}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                        <TextBlock Grid.Column="2"
                                   Text="{DynamicResource Loc.Main.Header.Status}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                        <TextBlock Grid.Column="3"
                                   Text="{DynamicResource Loc.Main.Header.Detail}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                        <TextBlock Grid.Column="4"
                                   Text="{DynamicResource Loc.Main.Header.Action}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}" />
                    </Grid>
                </Border>
                <!-- Item list -->
                <ListBox x:Name="DiagnosticListBox"
                         Grid.Row="1"
                         ItemsSource="{Binding DiagnosticItems}"
                         SelectedItem="{Binding CurrentDiagnosticItem, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch" />
                            <Setter Property="Padding"
                                    Value="0" />
                            <Setter Property="Margin"
                                    Value="0" />
                            <Setter Property="Background"
                                    Value="Transparent" />
                            <Setter Property="BorderThickness"
                                    Value="0" />
                            <Setter Property="Focusable"
                                    Value="False" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="18,11"
                                    Margin="6,4,6,4"
                                    Background="{Binding Status, Converter={StaticResource StatusToBg}}"
                                    BorderBrush="{DynamicResource ThemeRowBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                         Value="True">
                                                <Setter Property="BorderBrush"
                                                        Value="{DynamicResource ThemeTextPrimaryBrush}" />
                                                <Setter Property="BorderThickness"
                                                        Value="2" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding CategoryName}"
                                               FontSize="13"
                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,0,8,0" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Name}"
                                               FontSize="13"
                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding StatusText}"
                                               FontSize="13"
                                               Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Detail}"
                                               FontSize="12"
                                               Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"
                                               Margin="0,0,10,0" />
                                    <Button Grid.Column="4"
                                            Style="{StaticResource FixButton}"
                                            Content="{DynamicResource Loc.Main.FixItem}"
                                            Command="{Binding DataContext.FixItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            VerticalAlignment="Center">
                                        <Button.Visibility>
                                            <MultiBinding>
                                                <MultiBinding.Converter>
                                                    <conv:StatusToFixVisibilityConverter />
                                                </MultiBinding.Converter>
                                                <Binding Path="Status" />
                                            </MultiBinding>
                                        </Button.Visibility>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>