<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════ LIGHT THEME — 360-Style ═══════════ -->

    <!-- Core colors -->
    <Color x:Key="ThemeBg">#F5F7FA</Color>
    <Color x:Key="ThemeCardBg">#FFFFFF</Color>
    <Color x:Key="ThemeCardBorder">#E4E7EB</Color>
    <Color x:Key="ThemeHeaderBg">#FFFFFF</Color>
    <Color x:Key="ThemeTextPrimary">#2D3748</Color>
    <Color x:Key="ThemeTextSecondary">#718096</Color>
    <Color x:Key="ThemeAccentGreen">#38A169</Color>
    <Color x:Key="ThemeAccentOrange">#DD6B20</Color>
    <Color x:Key="ThemeAccentRed">#E53E3E</Color>
    <Color x:Key="ThemeRingBg">#EDF2F7</Color>
    <Color x:Key="ThemeRowBorder">#EDF2F7</Color>

    <!-- Summary card backgrounds -->
    <Color x:Key="ThemePassCardBg">#E6FFED</Color>
    <Color x:Key="ThemeWarnCardBg">#FFF8D6</Color>
    <Color x:Key="ThemeFailCardBg">#FFEBEB</Color>
    <Color x:Key="ThemePassCardText">#22863A</Color>
    <Color x:Key="ThemeWarnCardText">#B08800</Color>
    <Color x:Key="ThemeFailCardText">#CB2431</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="ThemeBgBrush" Color="{StaticResource ThemeBg}" />
    <SolidColorBrush x:Key="ThemeCardBgBrush" Color="{StaticResource ThemeCardBg}" />
    <SolidColorBrush x:Key="ThemeCardBorderBrush" Color="{StaticResource ThemeCardBorder}" />
    <SolidColorBrush x:Key="ThemeHeaderBgBrush" Color="{StaticResource ThemeHeaderBg}" />
    <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="{StaticResource ThemeTextPrimary}" />
    <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="{StaticResource ThemeTextSecondary}" />
    <SolidColorBrush x:Key="ThemeAccentGreenBrush" Color="{StaticResource ThemeAccentGreen}" />
    <SolidColorBrush x:Key="ThemeAccentOrangeBrush" Color="{StaticResource ThemeAccentOrange}" />
    <SolidColorBrush x:Key="ThemeAccentRedBrush" Color="{StaticResource ThemeAccentRed}" />
    <SolidColorBrush x:Key="ThemeRingBgBrush" Color="{StaticResource ThemeRingBg}" />
    <SolidColorBrush x:Key="ThemeRowBorderBrush" Color="{StaticResource ThemeRowBorder}" />
    <SolidColorBrush x:Key="ThemePassCardBgBrush" Color="{StaticResource ThemePassCardBg}" />
    <SolidColorBrush x:Key="ThemeWarnCardBgBrush" Color="{StaticResource ThemeWarnCardBg}" />
    <SolidColorBrush x:Key="ThemeFailCardBgBrush" Color="{StaticResource ThemeFailCardBg}" />
    <SolidColorBrush x:Key="ThemePassCardTextBrush" Color="{StaticResource ThemePassCardText}" />
    <SolidColorBrush x:Key="ThemeWarnCardTextBrush" Color="{StaticResource ThemeWarnCardText}" />
    <SolidColorBrush x:Key="ThemeFailCardTextBrush" Color="{StaticResource ThemeFailCardText}" />

    <!-- Button secondary bg -->
    <SolidColorBrush x:Key="ThemeSecondaryButtonBg" Color="{StaticResource ThemeRingBg}" />

</ResourceDictionary>
