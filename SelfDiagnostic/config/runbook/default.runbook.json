      "BindMethod": "SelfDiagnostic.Services.Executors.Tp.TpCheckExecutors.CheckTpOpticalResidualRiskAsync",
      "TimeoutMs": 8000,
      "Enabled": true,
      "Params": {
        "apiPath": "/api/tms/optical-risk",
        "fallbackFile": "config/opticalResidualRisk.mock.json"
      }
    },
    {
      "CheckId": "TP_13",
      "DisplayName": "定制规则-光学GR&R阈值检查",
      "Category": "OpticalPerformanceCheck",
      "BindDll": "SelfDiagnostic.Checks.Tp.dll",
      "BindMethod": "SelfDiagnostic.Services.Executors.Tp.TpCheckExecutors.CheckTpOpticalCustomGrrRuleAsync",
      "TimeoutMs": 6000,
      "Enabled": true,
      "Params": {
        "ruleName": "光学GR&R定制阈值",
        "metricKey": "grrPercent",
        "operator": "lte",
        "threshold": "8.50",
        "failReasonTemplate": "{metric}超限: 实际{actual}, 规则{required}"
      }
    },
    {
      "CheckId": "TP_14",
      "DisplayName": "定制规则-光学SNR阈值检查",
      "Category": "OpticalPerformanceCheck",
      "BindDll": "SelfDiagnostic.Checks.Tp.dll",
      "BindMethod": "SelfDiagnostic.Services.Executors.Tp.TpCheckExecutors.CheckTpOpticalCustomSnrRuleAsync",
      "TimeoutMs": 6000,
      "Enabled": true,
      "Params": {
        "ruleName": "光学SNR定制阈值",
        "metricKey": "snrDb",
        "operator": "gte",
        "threshold": "31.50",
        "failReasonTemplate": "{metric}不达标: 实际{actual}, 规则{required}"
      }
    },
